  "typography": {
    "fontFamilies": {
      "sans": {
        "name": "Geist",
        "fallback": "Geist Fallback",
        "usage": "Primary font for headings and body text",
        "weights": [400, 500, 600, 700]
      },
      "mono": {
        "name": "Geist Mono",
        "fallback": "Geist Mono Fallback",
        "usage": "Monospace font for code and technical content",
        "weights": [400, 500, 600, 700]
      }
    },
    "scale": {
      "xs": "0.75rem",
      "sm": "0.875rem",
      "base": "1rem",
      "lg": "1.125rem",
      "xl": "1.25rem",
      "2xl": "1.5rem",
      "3xl": "1.875rem",
      "4xl": "2.25rem",
      "5xl": "3rem",
      "6xl": "3.75rem"
    },
    "lineHeight": {
      "tight": "1.25",
      "normal": "1.5",
      "relaxed": "1.625",
      "loose": "2"
    },
    "fontWeight": {
      "normal": "400",
      "medium": "500",
      "semibold": "600",
      "bold": "700"
    }
  },
  "spacing": {
    "scale": {
      "0": "0",
      "1": "0.25rem",
      "2": "0.5rem",
      "3": "0.75rem",
      "4": "1rem",
      "5": "1.25rem",
      "6": "1.5rem",
      "8": "2rem",
      "10": "2.5rem",
      "12": "3rem",
      "16": "4rem",
      "20": "5rem",
      "24": "6rem",
      "32": "8rem"
    },
    "usage": {
      "component": "4-6 (1-1.5rem)",
      "section": "12-24 (3-6rem)",
      "container": "4-8 (1-2rem)"
    }
  },
  "borderRadius": {
    "base": "0.75rem",
    "sm": "calc(0.75rem - 4px)",
    "md": "calc(0.75rem - 2px)",
    "lg": "0.75rem",
    "xl": "calc(0.75rem + 4px)",
    "full": "9999px",
    "usage": {
      "buttons": "lg",
      "cards": "lg",
      "inputs": "md",
      "badges": "full"
    }
  },
  "shadows": {
    "sm": "0 1px 2px 0 rgb(0 0 0 / 0.05)",
    "base": "0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1)",
    "md": "0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1)",
    "lg": "0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1)",
    "xl": "0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1)"
  },
  "components": {
    "button": {
      "variants": {
        "primary": {
          "background": "primary",
          "text": "primary-foreground",
          "hover": "opacity-90"
        },
        "secondary": {
          "background": "secondary",
          "text": "secondary-foreground",
          "hover": "opacity-80"
        },
        "outline": {
          "background": "transparent",
          "text": "foreground",
          "border": "border",
          "hover": "background: accent"
        },
        "ghost": {
          "background": "transparent",
          "text": "foreground",
          "hover": "background: accent"
        },
        "destructive": {
          "background": "destructive",
          "text": "destructive-foreground",
          "hover": "opacity-90"
        }
      },
      "sizes": {
        "sm": "h-9 px-3 text-sm",
        "md": "h-10 px-4 py-2",
        "lg": "h-11 px-8 text-lg"
      }
    },
    "card": {
      "background": "card",
      "text": "card-foreground",
      "border": "border",
      "radius": "lg",
      "padding": "6"
    },
    "input": {
      "background": "background",
      "text": "foreground",
      "border": "input",
      "radius": "md",
      "height": "10",
      "padding": "3"
    },
    "badge": {
      "radius": "full",
      "padding": "px-2.5 py-0.5",
      "fontSize": "xs",
      "variants": {
        "default": "bg-primary text-primary-foreground",
        "secondary": "bg-secondary text-secondary-foreground",
        "success": "bg-green-500 text-white",
        "warning": "bg-yellow-500 text-white",
        "error": "bg-destructive text-destructive-foreground"
      }
    }
  },
  "animations": {
    "gradientShift": {
      "keyframes": "0%, 100% { background-position: 0% 50%; } 50% { background-position: 100% 50%; }",
      "duration": "8s",
      "timing": "ease",
      "iteration": "infinite"
    },
    "fadeIn": {
      "duration": "0.3s",
      "timing": "ease-in"
    },
    "slideIn": {
      "duration": "0.4s",
      "timing": "ease-out"
    }
  },
  "layout": {
    "container": {
      "maxWidth": "1280px",
      "padding": "px-4 md:px-6 lg:px-8"
    },
    "section": {
      "padding": "py-12 md:py-16 lg:py-24"
    },
    "navbar": {
      "height": "64px",
      "position": "fixed",
      "background": "background/80",
      "backdrop": "blur-lg"
    }
  },
  "breakpoints": {
    "sm": "640px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1280px",
    "2xl": "1536px"
  },
  "icons": {
    "library": "Lucide React",
    "sizes": {
      "sm": "16px",
      "md": "20px",
      "lg": "24px",
      "xl": "32px"
    }
  }
}
