{
  "name": "Viko kits",
  "private": true,
  "version": "0.1.7",
  "type": "module",
  "packageManager": "pnpm@10.11.1",
  "scripts": {
    "dev": "vite --port 5173 --strictPort",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "build:mac": "tauri build --target aarch64-apple-darwin",
    "build:mac:arm": "tauri build --target aarch64-apple-darwin",
    "build:mac:intel": "tauri build --target x86_64-apple-darwin",
    "build:win": "tauri build --target x86_64-pc-windows-msvc",
    "build:linux": "tauri build --target x86_64-unknown-linux-gnu",
    "build:all": "npm run build:mac && npm run build:win && npm run build:linux",
    "build:all:mac": "npm run build:mac:arm && npm run build:mac:intel",
    "build:remote": "TAURI_REMOTE_URL=${TAURI_REMOTE_URL} pnpm tauri:build",
    "build:remote:mac": "TAURI_REMOTE_URL=${TAURI_REMOTE_URL} pnpm build:mac",
    "build:remote:win": "TAURI_REMOTE_URL=${TAURI_REMOTE_URL} pnpm build:win",
    "bump:version": "node scripts/bump-version.mjs",
    "check:deps": "bash scripts/check-ffmpeg-deps.sh",
    "check:deps:win": "powershell -ExecutionPolicy Bypass -File scripts/check-ffmpeg-deps.ps1",
    "simulate:updater": "node scripts/simulate-updater-release.mjs",
    "release:local": "node scripts/local-release-upload.mjs"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.1.11",
    "@tanstack/react-table": "^8.21.3",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "~2",
    "@tauri-apps/plugin-deep-link": "~2",
    "@tauri-apps/plugin-fs": "~2",
    "@tauri-apps/plugin-log": "~2.6.0",
    "@tauri-apps/plugin-opener": "~2.4.0",
    "@tauri-apps/plugin-process": "~2",
    "@tauri-apps/plugin-updater": "~2",
    "better-auth": "^1.4.17",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "framer-motion": "^12.24.12",
    "i18next": "^25.8.0",
    "i18next-browser-languagedetector": "^8.2.0",
    "i18next-http-backend": "^3.0.2",
    "lucide-react": "^0.525.0",
    "next-themes": "^0.4.6",
    "posthog-js": "^1.335.3",
    "radix-ui": "^1.4.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.5.4",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.10.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.11",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "tw-animate-css": "^1.3.5",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vite-plugin-pwa": "^0.20.5"
  }
}
