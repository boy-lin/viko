{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:path:default",
    "core:window:default",
    "core:webview:default",
    "core:menu:default",
    "core:resources:default",
    "core:tray:default",
    "core:image:default",
    "dialog:default",
    "deep-link:default",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-read-dir",
    "fs:allow-stat",
    "fs:allow-remove",
    "fs:allow-home-read",
    "fs:allow-home-meta",
    "fs:allow-home-read-recursive",
    "fs:allow-home-meta-recursive",
    "fs:allow-home-write-recursive",
    "fs:allow-download-write-recursive",
    "log:default",
    "opener:default",
    "updater:allow-check",
    "updater:allow-download",
    "updater:allow-download-and-install",
    "updater:allow-install",
    "process:allow-restart"
  ]
}
