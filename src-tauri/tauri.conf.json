{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "viko",
  "version": "0.1.0",
  "identifier": "com.viko",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "",
    "frontendDist": "https://app.2342342.xyz"
  },
  "app": {
    "windows": [
      {
        "title": "viko",
        "width": 980,
        "height": 600,
        "minWidth": 980,
        "minHeight": 600,
        "maximized": false,
        "resizable": true,
        "devtools": true,
        "label": "main",
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self' https: http://localhost:*; script-src 'self' 'unsafe-inline' 'unsafe-eval' https: http://localhost:*; style-src 'self' 'unsafe-inline' https: http://localhost:*; img-src 'self' data: https: http:; connect-src 'self' https: http://localhost:* wss: ws:; font-src 'self' data: https:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/ffmpeg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "copyright": "",
    "category": "Utility",
    "shortDescription": "Video transcoding tool",
    "longDescription": "A video transcoding application built with Tauri"
  }
}
