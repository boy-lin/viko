{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "viko",
  "version": "0.1.6",
  "identifier": "com.viko",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "",
    "beforeBundleCommand": "bash scripts/fix-mac-dylibs.sh",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "viko",
        "width": 980,
        "height": 600,
        "minWidth": 980,
        "minHeight": 600,
        "maximized": false,
        "resizable": true,
        "devtools": true,
        "label": "main",
        "dragDropEnabled": true
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$CACHE/**"
        ]
      },
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "viko"
        ]
      }
    },
    "updater": {
      "endpoints": [
        "https://avi.2342342.xyz/api/app/latest"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQyOUY0M0NDRjE0NzNBNkIKUldSck9rZnh6RU9mMG1YM0pkeVRON3JnY0hHQXFUUzRLZ1BxbkpqMUtGZThSRmk1eldXYTNjKzcK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "app",
      "dmg",
      "msi"
    ],
    "resources": {
      "resources/ffmpeg": "resources/ffmpeg"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "copyright": "",
    "category": "Utility",
    "shortDescription": "Video transcoding tool",
    "longDescription": "A video transcoding application built with Tauri"
  }
}
